<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="581.0" prefWidth="769.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kfcglobaloperationsapp.IFTI_2310321.StockTransferController">
   <children>
      <Label layoutX="320.0" layoutY="20.0" text="Stock Transfer Dashboard" />

      <Label layoutX="50.0" layoutY="60.0" text="Select Item:" />
      <ComboBox fx:id="itemComboBox" layoutX="140.0" layoutY="56.0" prefWidth="150.0" />

      <Label layoutX="320.0" layoutY="60.0" text="Quantity:" />
      <TextField fx:id="quantityTextField" layoutX="390.0" layoutY="56.0" prefWidth="100.0" />

      <Label layoutX="50.0" layoutY="100.0" text="Source Warehouse:" />
      <ComboBox fx:id="sourceComboBox" layoutX="170.0" layoutY="96.0" prefWidth="150.0" />

      <Label layoutX="350.0" layoutY="100.0" text="Destination Outlet:" />
      <ComboBox fx:id="destinationComboBox" layoutX="470.0" layoutY="96.0" prefWidth="150.0" />

      <Button layoutX="320.0" layoutY="140.0" mnemonicParsing="false" onAction="#handleTransferStock" text="Initiate Transfer" />

      <TableView fx:id="transferTableView" layoutX="50.0" layoutY="190.0" prefHeight="350.0" prefWidth="670.0">
        <columns>
          <TableColumn fx:id="idCol" prefWidth="80.0" text="Transfer ID" />
          <TableColumn fx:id="itemCol" prefWidth="150.0" text="Item Name" />
          <TableColumn fx:id="sourceCol" prefWidth="150.0" text="Source" />
          <TableColumn fx:id="destCol" prefWidth="150.0" text="Destination" />
          <TableColumn fx:id="qtyCol" prefWidth="70.0" text="Qty" />
          <TableColumn fx:id="statusCol" prefWidth="90.0" text="Status" />
        </columns>
      </TableView>
   </children>
</AnchorPane>