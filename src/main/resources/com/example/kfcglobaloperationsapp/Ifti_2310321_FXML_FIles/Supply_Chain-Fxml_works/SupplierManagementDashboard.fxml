<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="581.0" prefWidth="769.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kfcglobaloperationsapp.IFTI_2310321.SupplierManagerController">
   <children>
      <Label layoutX="320.0" layoutY="30.0" text="Supplier Management Dashboard" />

      <Label layoutX="50.0" layoutY="80.0" text="Supplier ID:" />
      <TextField fx:id="idTextField" layoutX="130.0" layoutY="76.0" prefWidth="150.0" />

      <Label layoutX="320.0" layoutY="80.0" text="Supplier Name:" />
      <TextField fx:id="nameTextField" layoutX="420.0" layoutY="76.0" prefWidth="150.0" />

      <Label layoutX="50.0" layoutY="120.0" text="Contact Info:" />
      <TextField fx:id="contactTextField" layoutX="130.0" layoutY="116.0" prefWidth="150.0" />

      <Label layoutX="320.0" layoutY="120.0" text="Category:" />
      <ComboBox fx:id="categoryComboBox" layoutX="420.0" layoutY="116.0" prefWidth="150.0" />

      <Label layoutX="50.0" layoutY="160.0" text="Status:" />
      <ComboBox fx:id="statusComboBox" layoutX="130.0" layoutY="156.0" prefWidth="150.0" />

      <Button layoutX="350.0" layoutY="156.0" mnemonicParsing="false" onAction="#handleAddSupplier" text="Add Supplier" />
      <Button layoutX="450.0" layoutY="156.0" mnemonicParsing="false" onAction="#handleRemoveSupplier" text="Remove Supplier" />

      <TableView fx:id="supplierTableView" layoutX="50.0" layoutY="210.0" prefHeight="330.0" prefWidth="670.0">
        <columns>
          <TableColumn fx:id="idCol" prefWidth="90.0" text="Supplier ID" />
          <TableColumn fx:id="nameCol" prefWidth="200.0" text="Supplier Name" />
          <TableColumn fx:id="contactCol" prefWidth="150.0" text="Contact Info" />
          <TableColumn fx:id="categoryCol" prefWidth="130.0" text="Category" />
          <TableColumn fx:id="statusCol" prefWidth="100.0" text="Status" />
        </columns>
      </TableView>
   </children>
</AnchorPane>