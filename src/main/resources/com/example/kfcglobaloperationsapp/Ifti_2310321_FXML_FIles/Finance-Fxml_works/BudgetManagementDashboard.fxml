<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="581.0" prefWidth="769.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kfcglobaloperationsapp.IFTI_2310321.finance_manager.BudgetManagementController">
   <children>
      <Label layoutX="260.0" layoutY="15.0" text="Corporate Budget Management">
         <font><Font name="System Bold" size="18.0" /></font>
      </Label>

      <HBox layoutX="30.0" layoutY="60.0" spacing="15.0">
         <children>
            <ComboBox fx:id="yearCombo" prefWidth="120.0" promptText="Fiscal Year" />
            <ComboBox fx:id="regionCombo" prefWidth="120.0" promptText="Region" />
            <ComboBox fx:id="deptCombo" prefWidth="140.0" promptText="Department" />
            <Button mnemonicParsing="false" text="Load Budgets" />
         </children>
      </HBox>

      <TableView fx:id="budgetTable" layoutX="30.0" layoutY="100.0" prefHeight="250.0" prefWidth="420.0">
        <columns>
          <TableColumn fx:id="deptCol" prefWidth="110.0" text="Department" />
          <TableColumn fx:id="regionCol" prefWidth="90.0" text="Region" />
          <TableColumn fx:id="allocCol" prefWidth="110.0" text="Allocated ($)" />
          <TableColumn fx:id="utilCol" prefWidth="110.0" text="Utilized ($)" />
        </columns>
      </TableView>

      <VBox layoutX="470.0" layoutY="100.0" prefHeight="250.0" prefWidth="270.0" spacing="12.0" style="-fx-border-color: #ccc; -fx-padding: 15; -fx-background-color: #f9f9f9;">
         <children>
            <Label text="Edit Budget Allocation">
               <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <Label fx:id="selectedDeptLabel" text="Select from table..." textFill="#0056b3" />

            <Label text="New Allocated Amount ($):" />
            <TextField fx:id="newAmountField" promptText="Enter positive amount" />
            <Button mnemonicParsing="false" onAction="#handlePreviewChanges" prefWidth="240.0" style="-fx-background-color: #17a2b8; -fx-text-fill: white;" text="Preview Impact &amp; Check Risk" />

            <HBox spacing="10.0">
               <children>
                  <Label text="New Total:" />
                  <Label fx:id="previewTotalLabel" text="-" />
               </children>
            </HBox>
            <HBox spacing="10.0">
               <children>
                  <Label text="Variance:" />
                  <Label fx:id="varianceLabel" text="-" />
               </children>
            </HBox>
         </children>
      </VBox>

      <HBox layoutX="30.0" layoutY="370.0" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleSaveAllocation" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;" text="Confirm &amp; Save Changes" />
            <Button mnemonicParsing="false" onAction="#handleExportNotify" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #ffc107; -fx-font-weight: bold;" text="Export Report &amp; Notify" />
         </children>
      </HBox>

      <Label fx:id="statusLabel" layoutX="30.0" layoutY="520.0" prefWidth="710.0" text="System Ready." textFill="#5b5b5b">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
   </children>
</AnchorPane>