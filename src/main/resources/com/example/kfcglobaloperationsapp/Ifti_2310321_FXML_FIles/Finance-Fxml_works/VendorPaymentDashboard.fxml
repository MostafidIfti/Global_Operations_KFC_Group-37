<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="581.0" prefWidth="769.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kfcglobaloperationsapp.IFTI_2310321.finance_manager.VendorPaymentController">
   <children>
      <Label layoutX="260.0" layoutY="15.0" text="Vendor Invoice &amp; Payments">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>

      <HBox layoutX="30.0" layoutY="60.0" spacing="15.0">
         <children>
            <ComboBox fx:id="vendorFilter" prefWidth="150.0" promptText="Vendor Name" />
            <ComboBox fx:id="statusFilter" prefWidth="120.0" promptText="Status" />
            <Button mnemonicParsing="false" text="Apply Filters" />
         </children>
      </HBox>

      <TableView fx:id="invoiceTable" layoutX="30.0" layoutY="100.0" prefHeight="330.0" prefWidth="420.0">
        <columns>
          <TableColumn fx:id="invNumCol" prefWidth="80.0" text="Inv #" />
          <TableColumn fx:id="vendorCol" prefWidth="110.0" text="Vendor" />
          <TableColumn fx:id="amountCol" prefWidth="80.0" text="Amount" />
          <TableColumn fx:id="agingCol" prefWidth="60.0" text="Overdue" />
          <TableColumn fx:id="statusCol" prefWidth="80.0" text="Status" />
        </columns>
      </TableView>

      <VBox layoutX="470.0" layoutY="100.0" prefHeight="330.0" prefWidth="270.0" spacing="10.0" style="-fx-border-color: #ccc; -fx-padding: 10;">
         <children>
            <Label text="Verification Status:">
               <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <Label fx:id="verificationDetailsLabel" text="Select an invoice to review..." wrapText="true" />

            <Label text="Adjust Amount (If Discrepancy):" />
            <TextField fx:id="adjustAmountField" promptText="Enter final amount" />

            <Label text="Approval/Rejection Notes:" />
            <TextArea fx:id="notesArea" prefHeight="80.0" promptText="Enter details here..." wrapText="true" />

            <HBox spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleAction" style="-fx-background-color: #28a745; -fx-text-fill: white;" text="Approve" />
                  <Button mnemonicParsing="false" onAction="#handleAction" style="-fx-background-color: #ffc107;" text="Clarify" />
                  <Button mnemonicParsing="false" onAction="#handleAction" style="-fx-background-color: #dc3545; -fx-text-fill: white;" text="Reject" />
               </children>
            </HBox>
         </children>
      </VBox>

      <Button layoutX="30.0" layoutY="450.0" mnemonicParsing="false" onAction="#handleProcessPayments" prefHeight="35.0" prefWidth="250.0" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold;" text="Process Approved Payments (Batch)" />

      <Label fx:id="systemStatusLabel" layoutX="30.0" layoutY="510.0" prefWidth="710.0" text="System Ready." textFill="#616161">
         <font><Font name="System Bold" size="13.0" /></font></Label>
   </children>
</AnchorPane>