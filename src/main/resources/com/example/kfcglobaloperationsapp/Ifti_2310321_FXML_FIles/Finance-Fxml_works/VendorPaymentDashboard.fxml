<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kfcglobaloperationsapp.IFTI_2310321.Finance_Manager.VendorPaymentController">
   <children>
      <Label layoutX="320.0" layoutY="14.0" text="Vendor Payments &amp; Approval">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>

      <Label layoutX="20.0" layoutY="60.0" text="Filter by Vendor:" />
      <ComboBox fx:id="vendorFilterComboBox" layoutX="120.0" layoutY="56.0" prefWidth="150.0" />
      <Button layoutX="285.0" layoutY="56.0" mnemonicParsing="false" onAction="#loadInvoicesButtonOnClick" text="Load Pending Invoices" />

      <TableView fx:id="invoiceTableView" layoutX="20.0" layoutY="100.0" prefHeight="200.0" prefWidth="810.0">
        <columns>
          <TableColumn fx:id="invoiceNumCol" prefWidth="150.0" text="Invoice #" />
          <TableColumn fx:id="vendorCol" prefWidth="300.0" text="Vendor Name" />
          <TableColumn fx:id="amountCol" prefWidth="180.0" text="Amount ($)" />
          <TableColumn fx:id="statusCol" prefWidth="180.0" text="Status" />
        </columns>
      </TableView>

      <Button layoutX="370.0" layoutY="315.0" mnemonicParsing="false" onAction="#selectInvoiceButtonOnClick" text="Select Invoice for Review" />

      <Line endX="700.0" layoutX="120.0" layoutY="360.0" startX="-100.0" />

      <Label layoutX="20.0" layoutY="380.0" text="Reviewing:" />
      <Label fx:id="selectedInvoiceLabel" layoutX="90.0" layoutY="380.0" text="None selected" textFill="#0022ff" />

      <Label layoutX="20.0" layoutY="420.0" text="Action:" />
      <ComboBox fx:id="actionComboBox" layoutX="90.0" layoutY="416.0" prefWidth="200.0" />

      <Label layoutX="310.0" layoutY="420.0" text="Adjusted Amount ($):" />
      <TextField fx:id="adjustedAmountTextField" layoutX="440.0" layoutY="416.0" prefWidth="120.0" promptText="If applicable" />

      <Label layoutX="580.0" layoutY="420.0" text="Payment Method:" />
      <ComboBox fx:id="paymentMethodComboBox" layoutX="690.0" layoutY="416.0" prefWidth="140.0" />

      <Button layoutX="380.0" layoutY="470.0" mnemonicParsing="false" onAction="#processInvoiceButtonOnClick" text="Process Invoice" />

      <Label fx:id="systemOutputLabel" alignment="CENTER" layoutX="20.0" layoutY="530.0" prefWidth="810.0" text="Status: Waiting for action..." textFill="RED">
         <font>
            <Font name="System Bold" size="14.0" />
         </font></Label>
   </children>
</AnchorPane>