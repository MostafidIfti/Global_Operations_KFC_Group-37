<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="581.0" prefWidth="769.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kfcglobaloperationsapp.IFTI_2310321.finance_manager.FinancialReportController">
   <children>
      <Label layoutX="270.0" layoutY="30.0" text="Financial Reports Dashboard">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="50.0" layoutY="80.0" text="Report Type:" />
      <ComboBox fx:id="reportTypeComboBox" layoutX="130.0" layoutY="76.0" prefWidth="150.0" />
      <Label layoutX="300.0" layoutY="80.0" text="Time Period:" />
      <ComboBox fx:id="periodComboBox" layoutX="380.0" layoutY="76.0" prefWidth="120.0" />
      <Label layoutX="520.0" layoutY="80.0" text="Region:" />
      <ComboBox fx:id="regionComboBox" layoutX="570.0" layoutY="76.0" prefWidth="120.0" />

      <Button layoutX="320.0" layoutY="130.0" mnemonicParsing="false" onAction="#handleGenerateReport" text="Generate Report" />

      <TableView fx:id="reportTableView" layoutX="50.0" layoutY="180.0" prefHeight="350.0" prefWidth="670.0">
        <columns>
          <TableColumn fx:id="idCol" prefWidth="100.0" text="Report ID" />
          <TableColumn fx:id="typeCol" prefWidth="200.0" text="Report Type" />
          <TableColumn fx:id="regionCol" prefWidth="120.0" text="Region" />
          <TableColumn fx:id="periodCol" prefWidth="120.0" text="Period" />
          <TableColumn fx:id="amountCol" prefWidth="120.0" text="Amount ($)" />
        </columns>
      </TableView>
   </children>
</AnchorPane>