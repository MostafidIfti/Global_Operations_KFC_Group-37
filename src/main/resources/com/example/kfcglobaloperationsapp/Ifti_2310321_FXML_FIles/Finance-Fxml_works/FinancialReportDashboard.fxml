<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="581.0" prefWidth="769.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kfcglobaloperationsapp.IFTI_2310321.finance_manager.FinancialReportController">
   <children>
      <Label layoutX="260.0" layoutY="15.0" text="Financial Reporting Analytics">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>

      <HBox layoutX="30.0" layoutY="60.0" spacing="15.0">
         <children>
            <ComboBox fx:id="reportTypeCombo" prefWidth="180.0" promptText="Select Report Type" />
            <ComboBox fx:id="timePeriodCombo" prefWidth="150.0" promptText="Time Period" />
            <ComboBox fx:id="regionCombo" prefWidth="150.0" promptText="Select Region" />
         </children>
      </HBox>

      <HBox layoutX="30.0" layoutY="100.0" spacing="15.0">
         <children>
            <DatePicker fx:id="startDatePicker" prefWidth="140.0" promptText="Start Date" />
            <DatePicker fx:id="endDatePicker" prefWidth="140.0" promptText="End Date" />
            <Button mnemonicParsing="false" onAction="#handleGenerateReport" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;" text="Generate Report" />
         </children>
      </HBox>

      <TableView fx:id="reportTable" layoutX="30.0" layoutY="150.0" prefHeight="250.0" prefWidth="420.0">
        <columns>
          <TableColumn fx:id="metricCol" prefWidth="140.0" text="Line Item" />
          <TableColumn fx:id="actualCol" prefWidth="90.0" text="Actual ($)" />
          <TableColumn fx:id="budgetCol" prefWidth="90.0" text="Budget ($)" />
          <TableColumn fx:id="varianceCol" prefWidth="90.0" text="Variance (%)" />
        </columns>
      </TableView>

      <PieChart fx:id="visualChart" layoutX="470.0" layoutY="150.0" prefHeight="250.0" prefWidth="280.0" style="-fx-border-color: #cccccc; -fx-background-color: #f9f9f9;" title="Report Visuals" />

      <HBox alignment="CENTER_LEFT" layoutX="30.0" layoutY="440.0" spacing="15.0" style="-fx-border-color: #ddd; -fx-padding: 10;">
         <children>
            <Label text="Export Tools:">
               <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <ComboBox fx:id="exportFormatCombo" prefWidth="100.0" promptText="Format" />
            <Button mnemonicParsing="false" onAction="#handleExportReport" style="-fx-background-color: #17a2b8; -fx-text-fill: white;" text="Export Document" />
            <Button mnemonicParsing="false" onAction="#handleSaveAndNotify" style="-fx-background-color: #007bff; -fx-text-fill: white;" text="Save to Repository &amp; Email CFO" />
         </children>
      </HBox>

      <Label fx:id="statusLabel" alignment="CENTER" layoutX="30.0" layoutY="520.0" prefWidth="710.0" text="Select parameters to generate report." textFill="#6b6b6b" />
   </children>
</AnchorPane>