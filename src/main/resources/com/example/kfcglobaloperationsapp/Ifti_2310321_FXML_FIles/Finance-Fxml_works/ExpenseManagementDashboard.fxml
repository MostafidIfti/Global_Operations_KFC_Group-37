<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="581.0" prefWidth="769.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kfcglobaloperationsapp.IFTI_2310321.finance_manager.ExpenseManagementController">
   <children>
      <Label layoutX="260.0" layoutY="15.0" text="Department Expense Management">
         <font><Font name="System Bold" size="18.0" /></font>
      </Label>

      <TableView fx:id="expenseTable" layoutX="20.0" layoutY="60.0" prefHeight="250.0" prefWidth="730.0">
        <columns>
          <TableColumn fx:id="idCol" prefWidth="90.0" text="Expense ID" />
          <TableColumn fx:id="deptCol" prefWidth="150.0" text="Department" />
          <TableColumn fx:id="catCol" prefWidth="150.0" text="Category" />
          <TableColumn fx:id="amountCol" prefWidth="120.0" text="Amount ($)" />
          <TableColumn fx:id="statusCol" prefWidth="210.0" text="Status" />
        </columns>
      </TableView>

      <VBox layoutX="20.0" layoutY="320.0" prefHeight="100.0" prefWidth="730.0" spacing="8.0" style="-fx-border-color: #ccc; -fx-padding: 10; -fx-background-color: #f9f9f9;">
         <children>
            <Label text="Expense Details &amp; Compliance Check">
               <font><Font name="System Bold" size="14.0" /></font>
            </Label>
            <Label fx:id="detailsLabel" text="Select an expense from the table..." textFill="#0056b3" />
            <Label fx:id="documentLabel" text="-" />
            <Label fx:id="warningLabel" text="-" />
         </children>
      </VBox>

      <VBox layoutX="20.0" layoutY="430.0" prefHeight="100.0" prefWidth="730.0" spacing="10.0">
         <children>
            <HBox spacing="10.0">
               <children>
                  <Label text="Remarks / Reason for Decision:" />
                  <Label text="(Mandatory if rejecting)" textFill="#797979">
                     <font><Font name="System Italic" size="12.0" /></font>
                  </Label>
               </children>
            </HBox>
            <TextArea fx:id="remarksArea" prefHeight="50.0" prefWidth="730.0" promptText="Enter detailed remarks here..." />

            <HBox spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleAction" prefWidth="150.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;" text="Approve Expense" />
                  <Button mnemonicParsing="false" onAction="#handleAction" prefWidth="150.0" style="-fx-background-color: #ffc107; -fx-font-weight: bold;" text="Request Clarification" />
                  <Button mnemonicParsing="false" onAction="#handleAction" prefWidth="150.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold;" text="Reject Expense" />
               </children>
            </HBox>
         </children>
      </VBox>

      <Label fx:id="systemStatusLabel" layoutX="20.0" layoutY="550.0" prefWidth="730.0" text="System Ready." textFill="#5b5b5b">
         <font><Font name="System Bold" size="13.0" /></font>
      </Label>
   </children>
</AnchorPane>