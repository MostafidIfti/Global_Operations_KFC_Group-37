<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="581.0" prefWidth="769.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kfcglobaloperationsapp.IFTI_2310321.SupplierEvaluationController">
   <children>
      <Label layoutX="320.0" layoutY="30.0" text="Supplier Performance Evaluation" />

      <Label layoutX="50.0" layoutY="80.0" text="Select Supplier:" />
      <ComboBox fx:id="supplierComboBox" layoutX="150.0" layoutY="76.0" prefWidth="170.0" />

      <Label layoutX="350.0" layoutY="80.0" text="Quality Rating:" />
      <ComboBox fx:id="ratingComboBox" layoutX="440.0" layoutY="76.0" prefWidth="150.0" />

      <Label layoutX="50.0" layoutY="130.0" text="Manager Feedback:" />
      <TextField fx:id="feedbackTextField" layoutX="170.0" layoutY="126.0" prefWidth="420.0" promptText="Enter detailed remarks here..." />

      <Button layoutX="330.0" layoutY="180.0" mnemonicParsing="false" onAction="#handleSaveEvaluation" text="Submit Evaluation" />

      <TableView fx:id="evalTableView" layoutX="50.0" layoutY="230.0" prefHeight="300.0" prefWidth="670.0">
        <columns>
          <TableColumn fx:id="idCol" prefWidth="90.0" text="Eval ID" />
          <TableColumn fx:id="supplierCol" prefWidth="180.0" text="Supplier Name" />
          <TableColumn fx:id="ratingCol" prefWidth="120.0" text="Rating" />
          <TableColumn fx:id="feedbackCol" prefWidth="280.0" text="Feedback / Remarks" />
        </columns>
      </TableView>
   </children>
</AnchorPane>