<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="581.0" prefWidth="769.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.kfcglobaloperationsapp.IFTI_2310321.InventoryManagerController">
   <children>
      <Label layoutX="260.0" layoutY="39.0" text="Warehouse Inventory Tracker">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="52.0" layoutY="94.0" text="Current Stock Levels" textFill="#b02525">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>

      <TableView fx:id="inventoryTableView" layoutX="52.0" layoutY="136.0" prefHeight="334.0" prefWidth="662.0">
        <columns>
          <TableColumn fx:id="itemNameCol" prefWidth="250.0" text="Item Name" />
          <TableColumn fx:id="currentStockCol" prefWidth="120.0" text="Current Stock" />
          <TableColumn fx:id="reorderLevelCol" prefWidth="140.0" text="Reorder Level" />
          <TableColumn fx:id="statusCol" prefWidth="150.0" text="Status" />
        </columns>
      </TableView>

      <Button layoutX="52.0" layoutY="498.0" mnemonicParsing="false" onAction="#handleShowAllStock" text="View All Inventory">
         <font>
            <Font size="14.0" />
         </font>
      </Button>

      <Button layoutX="561.0" layoutY="498.0" mnemonicParsing="false" onAction="#handleShowLowStock" text="Filter: Needs Restock" textFill="#b02525">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
   </children>
</AnchorPane>